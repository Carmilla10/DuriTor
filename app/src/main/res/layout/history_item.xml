<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingBottom="16dp">

    <!-- Date Header -->
    <TextView
        android:id="@+id/dateHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="08 June 2026"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp"
        android:paddingTop="8dp" />

    <!-- Time -->
    <TextView
        android:id="@+id/historyTime"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="03:45 PM"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:layout_marginBottom="4dp" />

    <!-- Alert -->
    <TextView
        android:id="@+id/historyAlert"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Durian Fall Detected!"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <!-- Location: Orchard • Region -->
    <TextView
        android:id="@+id/historyLocation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Orchard A • Region A"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:layout_marginBottom="4dp" />

    <!-- Tree -->
    <TextView
        android:id="@+id/historyTree"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="TM001 - Musang King"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:layout_marginBottom="8dp" />

    <!-- Image -->
    <ImageView
        android:id="@+id/historyImage"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_image_rounded"
        android:clipToOutline="true"
        android:scaleType="centerCrop"
        android:visibility="gone" />

    <!-- Collect & Delete - After Image -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <TextView
            android:id="@+id/collectButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Collect"
            android:textColor="@color/primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingEnd="16dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/deleteButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Delete"
            android:textColor="@color/status_error"
            android:textSize="14sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="12dp"
        android:background="@color/divider" />

</LinearLayout>