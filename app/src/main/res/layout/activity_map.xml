<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Map &amp; Navigation"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="#2E7D32" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Latitude: --"
            android:textSize="18sp"
            android:layout_marginTop="24dp"
            android:id="@+id/mapLatitudeText" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Longitude: --"
            android:textSize="18sp"
            android:layout_marginTop="8dp"
            android:id="@+id/mapLongitudeText" />

        <Button
            android:id="@+id/refreshLocationButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Refresh GPS"
            android:layout_marginTop="16dp"
            android:backgroundTint="#2E7D32" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Navigate to Orchard"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp" />

        <Spinner
            android:id="@+id/mapOrchardSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp" />

        <Button
            android:id="@+id/navigateButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Open Navigation"
            android:layout_marginTop="16dp"
            android:backgroundTint="#1565C0" />

    </LinearLayout>

</ScrollView>   